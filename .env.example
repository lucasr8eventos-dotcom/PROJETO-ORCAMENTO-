# ─────────────────────────────────────────────────────────
# IDENTIDADE DA EMPRESA (obrigatório personalizar)
# ─────────────────────────────────────────────────────────
REACT_APP_EMPRESA_NOME=OpSuite
REACT_APP_EMPRESA_SIGLA=OP
REACT_APP_EMPRESA_TAGLINE=Plataforma Operacional

# ─────────────────────────────────────────────────────────
# CORES (opcional — deixe em branco para usar o padrão)
# Use cores HEX (#RRGGBB)
# ─────────────────────────────────────────────────────────
# Cor da barra lateral e botões principais (padrão: #181714)
REACT_APP_COR_NAVBAR=

# Cor de destaque/links/relatórios (padrão: #185FA5)
REACT_APP_COR_DESTAQUE=

# ─────────────────────────────────────────────────────────
# BACKEND (obrigatório — URL do serviço Railway)
# ─────────────────────────────────────────────────────────
REACT_APP_API_URL=https://SEU-BACKEND.up.railway.app
